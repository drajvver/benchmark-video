# Example environment file for docker-compose.deploy.yml or docker-compose.ghcr.yml
# Copy this to .env and fill in your values.

# ---------------------------------------------------------------------------
# REQUIRED: Database connection URL
# ---------------------------------------------------------------------------
# For Supabase free tier:
#   DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.XXXXXXXXXXXXXXXX.supabase.co:5432/postgres?sslmode=require
#
# For Neon:
#   DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require
#
# For self-hosted Postgres:
#   DATABASE_URL=postgresql://benchmark:password@your-host:5432/benchmark
DATABASE_URL=

# ---------------------------------------------------------------------------
# REQUIRED: Secret key for JWT token generation
# ---------------------------------------------------------------------------
# Generate one with: openssl rand -hex 32
SECRET_KEY=

# ---------------------------------------------------------------------------
# OPTIONAL: CORS origins
# ---------------------------------------------------------------------------
# Only needed if you host frontend separately from backend.
# Default ["*"] allows all origins (convenient but less secure).
# CORS_ORIGINS=["https://your-domain.com","https://app.your-domain.com"]

# ---------------------------------------------------------------------------
# OPTIONAL: Frontend API URL override
# ---------------------------------------------------------------------------
# Only needed if frontend and backend are on different origins.
# Default /api/v1 works when nginx proxies API calls to backend.
# API_URL=https://api.your-domain.com/api/v1
